        { "@type": "schema:PropertyValue", "schema:name": "RMSE", "schema:description": "Root Mean Square Error of prediction", "schema:unitCode": "DAY" },
        { "@type": "schema:PropertyValue", "schema:name": "MAE", "schema:description": "Mean Absolute Error of prediction", "schema:unitCode": "DAY" },
        { "@type": "schema:PropertyValue", "schema:name": "MSE", "schema:description": "Mean Squared Error of prediction", "schema:unitCode": "DAY" },
        { "@type": "schema:PropertyValue", "schema:name": "R2", "schema:description": "Coefficient of determination of prediction" }
      ]
