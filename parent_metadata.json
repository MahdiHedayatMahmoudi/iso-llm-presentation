    "schema:url": "https://doi.org/10.5281/zenodo.<YOUR_RECORD_ID>"
  },

  "prov:wasRevisionOf": "https://doi.org/10.5281/zenodo.<YOUR_RECORD_ID>.v1.0.0",

  "schema:releaseNotes": "Version 1.1.2 (2026-03-16): Final PHASE dataset release. Each phase-year dataset consists of interpolated DOY predictions (GeoTIFF), local uncertainty layers as BAM posterior standard error (BSE), and validation accuracy metrics (VAM CSV). Coverage spans mostly 1993–2024 with documented exceptions.",



  "skos:note": [
    "Most phenological phases are available for 1993–2024.",
    "High-level exceptions exist for certain crops and years, detailed in PhaseNumber.xlsx (e.g., crop 207 missing 1993–2013; crop 208 missing 2023–2024; isolated phase-year gaps such as 203-15_2022, 205-17_2022)."
  ],



